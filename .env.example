# Discord Bot Token — https://discord.com/developers/applications -> Bot -> Token
DISCORD_TOKEN=

# Tu ID de usuario de Discord (click derecho sobre tu nombre -> "Copiar ID de usuario", activa modo desarrollador primero)
# Solo este usuario puede usar sh.servers
ADMIN_ID=

# Giphy API Key — https://developers.giphy.com (Tenor fue deprecado en enero 2026)
GIPHY_KEY=

# Google Custom Search Engine ID — https://programmablesearchengine.google.com
ID_BUSCADOR_GOOGLE=

# Google Custom Search API Key — https://console.cloud.google.com -> Credentials
GOOGLE_CUSTOM_SEARCH=

# Danbooru credentials — https://danbooru.donmai.us/profile
DANBOORU_LOGIN=
DANBOORU_KEY=

# OpenExchangeRates API Key (free plan) — https://openexchangerates.org/signup/free
OPEN_EXCHANGE=

# Spoonacular API Key (free: 150 req/dia, sin tarjeta) — https://spoonacular.com/food-api/console
SPOONACULAR_KEY=

# OMDB API Key (free: 1000 req/dia) — https://www.omdbapi.com/apikey.aspx
OMDB_KEY=
